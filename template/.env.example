# MCP Boilerplate — copy to .env and fill in values

# Public base URL of this server (no trailing slash).
# Used in OAuth discovery metadata — must match the URL clients reach.
# For local dev with devtunnel:
BASE_URL=https://your-tunnel-id-8080.use.devtunnels.ms
# For pure API-key local dev:
# BASE_URL=http://localhost:8080

# API key(s) for x-api-key authentication (comma-separated)
API_KEYS=your-secret-api-key

# Service display info
SERVICE_NAME=MCP Boilerplate
SERVICE_OWNER=Your Org
SERVICE_VERSION=1.0.0

# ── Azure Entra (OAuth2) ─────────────────────────────────────────────────────
# Required for OAuth2 / Claude.ai web connector support.
# Leave blank to run in API-key-only mode.

AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
# Client secret for the token proxy (recommended for production confidential clients).
# Leave blank only if "Allow public client flows" is enabled in Azure App Registration.
AZURE_CLIENT_SECRET=

# ── Optional tuning ──────────────────────────────────────────────────────────
# MAX_CONCURRENT_STREAMS=20
# QUEUE_WAIT_TIMEOUT=5
# HARD_STREAM_TIMEOUT=300
# IDLE_STREAM_TIMEOUT=60
# LOG_LEVEL=INFO
